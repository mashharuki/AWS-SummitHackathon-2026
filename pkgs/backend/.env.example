# ローカル開発用環境変数
# 実際にAWSリソースを呼ぶ場合は本物の値に置き換えてください

# 環境
ENVIRONMENT=dev
NODE_ENV=development
AWS_REGION=ap-northeast-1

# Cognito (実際のIDを使う場合はCDKデプロイ後の値を設定)
COGNITO_USER_POOL_ID=ap-northeast-1_XXXXXXXXX
COGNITO_CLIENT_ID=local-client-id-placeholder

# DynamoDB テーブル名 (CDK命名規則: saborou-{table}-dev)
DYNAMODB_TABLE_USERS=saborou-users-dev
DYNAMODB_TABLE_CONNECTIONS=saborou-service-connections-dev
DYNAMODB_TABLE_TASK_CANDIDATES=saborou-task-candidates-dev
DYNAMODB_TABLE_TASKS=saborou-tasks-dev
DYNAMODB_TABLE_PROPOSALS=saborou-proposals-dev
DYNAMODB_TABLE_HONNE_DATA=saborou-honne-data-dev
DYNAMODB_TABLE_PERSONAS=saborou-personas-dev

# Secrets Manager ARN (ローカルはプレースホルダー — 実際の呼び出し時はエラー)
SLACK_SIGNING_SECRET_ARN=arn:aws:secretsmanager:ap-northeast-1:000000000000:secret:saborou/slack-signing-secret-local
SLACK_CLIENT_SECRET_ARN=arn:aws:secretsmanager:ap-northeast-1:000000000000:secret:saborou/slack-client-secret-local

# OAuth state HMAC シークレット (ローカル開発用の任意の文字列)
OAUTH_STATE_SECRET=local-dev-oauth-state-secret-32bytes!!

# EventBridge (webhook Lambda のみ使用)
EVENT_BUS_NAME=saborou-events-dev
