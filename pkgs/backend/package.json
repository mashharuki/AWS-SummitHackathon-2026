{
  "name": "backend",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "vitest",
    "dev": "tsx ./src/index.ts",
    "build": "esbuild --bundle --outfile=./dist/index.js --platform=node --target=node20 ./src/handler.ts",
    "zip": "zip -j lambda.zip dist/index.js",
    "update": "aws lambda update-function-code --zip-file fileb://lambda.zip --function-name hello",
    "deploy": "run-s build zip update"
  },
  "devDependencies": {
    "@hono/node-server": "^2.0.2",
    "@hono/swagger-ui": "^0.6.1",
    "esbuild": "^0.21.4",
    "npm-run-all2": "^6.2.0",
    "tsx": "^4.22.0",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "hono": "^4.12.19"
  }
}
